              }
            }
          }
        }
      },
      "put" : {
        "summary" : "Update a task",
        "requestBody" : {
          "content" : {
            "application/json" : {
              "schema" : {
                "$ref" : "#/components/schemas/Task"
              },
              "example" : "{\"name\": \"My task\", \"completed\": false, \"createdAt\": \"2016.07.03\"}"
            }
          }
        },
        "responses" : {
          "200" : {
            "description" : "Success",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Task"
                },
                "example" : "{\"id\": \"47ee3550-b619-11e6-8408-0bdb025a7cfa\", \"name\": \"My task\", \"completed\": false, \"createdAt\": \"2016.07.03\"}"
              }
            }
          }
        },
        "security" : [ {
          "HTTP_BASIC" : [ ]
        } ]
      },
      "delete" : {
        "summary" : "Delete a task",
        "responses" : {
          "200" : {
            "description" : "Success"
          }
        },
        "security" : [ {
          "HTTP_BASIC" : [ ]
        } ]
      },
      "parameters" : [ {
        "name" : "taskId",
        "in" : "path",
        "required" : true,
        "description" : "Unique identifier of the task",
        "schema" : {
          "type" : "string",
          "description" : "Unique identifier of the task"
        },
        "example" : "47ee3550-b619-11e6-8408-0bdb025a7cfa"
      } ]
    }
  },
  "components" : {
    "schemas" : {
      "Task" : {
        "type" : "object",
        "required" : [ "completed", "id", "name" ],
        "description" : "A task to be done",
        "properties" : {
          "id" : {
            "type" : "string",
            "description" : "Auto-generated primary key field",
            "example" : "3fa2eb40-b61c-11e6-9de0-fdbe71bceebb"
          },
          "name" : {
            "type" : "string",
            "example" : "My task"
          },
          "completed" : {
            "type" : "boolean"
          },
          "createdAt" : {
            "type" : "string",
            "example" : "2016.10.06"
          }
        },
        "example" : "{\"id\": \"47ee3550-b619-11e6-8408-0bdb025a7cfa\", \"name\": \"My task\", \"completed\": false, \"createdAt\": \"2016.07.03\"}"
      },
      "Error" : {
        "type" : "object",
        "required" : [ "code" ],
        "description" : "This general error structure is used throughout this API",
        "properties" : {
          "code" : {
            "type" : "integer",
            "minimum" : 400,
            "maximum" : 599
          },
          "description" : {
            "type" : "string",
            "example" : "Bad query parameter"
          },
          "reasonPhrase" : {
            "type" : "string",
            "example" : "Bad Request"
          }
        },
        "example" : "{\"code\": 400, \"description\": \"Bad query parameter\", \"reasonPhrase\": \"Bad Request\"}"
      }
    },
    "securitySchemes" : {
      "HTTP_BASIC" : {
        "type" : "http",
        "scheme" : "basic",
        "description" : "Basic HTTP authentication"
      }
    }
  }
